@using System.Data

@{
    ViewData["Title"] = "Footer_Logo";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    DataSet FooterLogoVeriKumesi = ViewBag.FooterLogoKismi as DataSet;
}

<div class="container">
    <div class="page-inner"> 
        <div class="page-header">
            <h3 class="fw-bold mb-3">Tables</h3>
            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Listeleri</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Operasyonlari</a>
                </li>
            </ul>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Hoverable Table</div>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th scope="col">Alt Baslik</th>
                                    <th scope="col">Fotograf</th>
                                    <th scope="col">Guncelle</th>
                                    @* <th scope="col">Sil</th> *@
                                </tr>
                            </thead>
                            <tbody>
                                    <tr>
                                        <td class="text-muted">@FooterLogoVeriKumesi.Tables[0].Rows[0]["FooterLogoAltBaslik"]</td>
                                        <td class="text-muted"><a href="@FooterLogoVeriKumesi.Tables[0].Rows[0]["FooterLogoFotoUrl"]" target="_blank" style="text-decoration: none; padding: 10px; background-color: var(--primary-accent); color: black; border-radius: 4px; box-shadow: rgba(100, 100, 111, 0.2) 4px 4px 5px 2px;">Fotoğrafı aç</a></td>
                                        <td><a href="/Admin/Footer_Logo_Update/@FooterLogoVeriKumesi.Tables[0].Rows[0]["FooterLogoId"]" class="btn btn-success">Guncelle</a></td>
                                        @* <td><a href="/TopCategoryArea/DeleteTopCategoryArea/@esya.TopCategoryAreaId" class="btn btn-danger">Sil</a></td> *@
                                    </tr>
                            </tbody>
                        </table>
                        @* <a href="/TopCategoryArea/CreateTopCategoryArea/" class="btn btn-primary">Yeni One Cikan Kategori Ekle</a> *@

                    </div>
                </div>

            </div>
        </div>
    </div>
</div> 

