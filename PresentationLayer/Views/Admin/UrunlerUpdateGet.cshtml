@using System.Data

@{
    ViewData["Title"] = "UrunlerUpdateGet";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    DataSet UrunlerUpdateDataSet = ViewBag.UrunUpdateGetViewBag as DataSet;
}
<style>
    /* Örnek projedeki yükleme alanının şık görünmesi için küçük bir stil */
    .yukleme-alani-benimStyle {
        border: 2px dashed #dee2e6;
        padding: 25px;
        text-align: center;
        border-radius: 8px;
        background: #f8f9fa;
        cursor: pointer;
        transition: background 0.2s ease-in-out;
    }
    .yukleme-alani-benimStyle:hover {
        background: #e9ecef;
    }
</style>


<div class="container">
    <div class="page-inner"> 
        <div class="page-header">
            <h3 class="fw-bold mb-3">One Cikan Kategoriler Listesi</h3>
            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Listeleri</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Operasyonlari</a>
                </li>
            </ul>
        </div>
            <div class="row">
              <div class="col-md-12">
                <div class="card">
                  <div class="card-header">
                    <div class="card-title">Yeni One Cikan Kategori Guncelle</div>
                  </div>
                  <div class="card-body">
                     <form role="form" action="/admin/UrunlerUpdatePost" method="post" enctype="multipart/form-data">
                         <input type="hidden" name="UrunIdParametre" value="@UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunId"]">
                         <input type="hidden" name="mevcutFotografParametre" value="@UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunlerKapakFoto1"]">
                         
                         <div class="col-md-12">
                             <label>Urun Ismi</label>
                             <textarea class="form-control" name="UrunIsimParametre" rows="1" placeholder="yer tutucu">@UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunIsim"]</textarea>
                         </div>
                         <br />
                         <div class="col-md-12">
                             <label>Urun Aciklama</label>
                             <textarea class="form-control" name="UrunAciklamaParametre" rows="4">@UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunAciklama"]</textarea>
                         </div>
                         <br />
                         <div class="col-md-3">
                            <label>Urun Fiyat</label>
                            <input type="number" class="form-control" name="UrunFiyatParametre" step="0.01" min="0" value="@UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunFiyat"]" />
                         </div>
                         <br /><br />
                         <div class="col-md-6">
                            <label class="form-label d-block mb-2">Kapak Fotografi Guncelle</label>
                            <div class="yukleme-alani-benimStyle" onclick="document.getElementById('fileInput').click()">
                                <p class="mb-1 fw-bold">Tiklayin Veya Resmi Buraya Surukleyip Birakin</p>
                                <p class="text-muted small mb-0">PNG, JPG, WEBP (Maks. 5MB)</p>
                                <input type="file" class="d-none" id="fileInput" name="UrunKapakFotoUrlParametre" accept="image/*" onchange="yuklenenResmiGoruntule(event)"/>   
                            </div>
                        </div>



                        <div class="col-md-6">
                            <label class="form-label d-block mb-2 fw-bold"> Mevcut Kapak Fotograf </label>
                            <div class="p-2 border rounded bg-light text-center" style="min-height: 145px; display: flex; align-items: center; justify-content: center;">
                                    @foreach (DataRow sira in UrunlerUpdateDataSet.Tables[0].Rows)
                                    {
                                        <img id="onizleme" src="@sira["UrunlerKapakFoto1"]" style="max-width:100%; max-height:130px; height:auto; border-radius:6px; object-fit: contain;" />

                                    }
                            </div>
                        </div>
                        <br />
                         <br />

                         <div class="col-md-6">
                             <label>Kategori</label>
                             <select class="form-control" id="KategoriSec" placeholder="Kategori Secin">
                                    <option value="">Kategori Secin</option>
                                    @{
                                        foreach (DataRow sira in UrunlerUpdateDataSet.Tables[2].Rows)
                                        {
                                            <option value="@sira["kategoriId"]">@sira["kategoriIsim"]</option>
                                        }
                                    }
                             </select>
                         </div>
                         <br />
                            <div id="olusanButon" class="margin-top: 12px;"></div>


                         <br />
                         <br />
                         <div class="col-md-6">
                             <select class="form-control" name="UrunStatusParametre" placeholder="Aktifligi Belirleyin">
                                    @{
                                        int aktiflikPasiflik = Convert.ToInt16(UrunlerUpdateDataSet.Tables[0].Rows[0]["UrunStatus"]);
                                        switch (aktiflikPasiflik)
                                        {
                                            case 1:
                                                    <option value="1">Aktif</option>
                                                    <option value="0">Pasif</option>
                                                    break;
                                            case 0:<option value="0">Pasif</option>
                                                    <option value="1">Aktif</option>
                                                    break;
                                            default: break;
                                        }
                                    }
                             </select>
                             <br />
                         </div>

                         <button type="submit" class="btn btn-primary">One Cikan Kategori Guncelle</button>
                     </form>
                  </div>
                </div>
            </div>
        </div>
    </div>
</div> 

<script>
    function yuklenenResmiGoruntule(event) {
        const secilenIlkDosya = event.target.files[0]; // Seçilen ilk dosyayı al
        const onizleme = document.getElementById('onizleme'); // Resim etiketini yakala

        if (!secilenIlkDosya) return;

        // 1. GÜVENLİK KONTROLÜ: Seçilen şey gerçekten resim mi?
        if (!secilenIlkDosya.type.startsWith('image/')) {
            alert("Lütfen geçerli bir resim dosyası seçiniz.");
            event.target.value = ""; // Seçimi temizle
            return;
        }

        // 2. BOYUT KONTROLÜ: Resim 5MB'tan büyük mü?
        const maxBuyukluk = 5 * 1024 * 1024; // 5 Megabayt bayt cinsinden
        if (secilenIlkDosya.size > maxBuyukluk) {
            alert("Seçtiğiniz resim 5MB'tan küçük olmalıdır.");
            event.target.value = ""; // Seçimi temizle
            return;
        }

        // 3. ANLIK ÖNİZLEME OLUŞTURMA
        const url = URL.createObjectURL(secilenIlkDosya); // Seçilen resmi tarayıcı hafızasında geçici bir linke dönüştür
        onizleme.src = url; // Ekrandaki mevcut resmin yerine bu yeni geçici linki bas
    }
</script>

<script>
    // buradaki "Map()" kodu verileri (key(id), value(string vb.)) seklinde tutar. peki birden fazla value alabilir mi?
    // secilen butun kategori verileri bu "Map()" icinde tutulur. ornek: 14=Elektronik, 27=Giyim, 8=Mobilya
    const IdveIsimAlanMapKismi = new Map();
    @foreach (DataRow siraUrunKategori in UrunlerUpdateDataSet.Tables[1].Rows)
    {
        var kategoriIsim = "";
        
        @foreach(DataRow siraKategori in UrunlerUpdateDataSet.Tables[2].Rows)
        {
            if (siraKategori["kategoriId"].ToString() == siraUrunKategori["kategoriId"].ToString())
            {
                kategoriIsim = siraKategori["kategoriIsim"].ToString();
                break;
            }
        }
        <text>
                IdveIsimAlanMapKismi.set('@siraUrunKategori["kategoriId"]', '@kategoriIsim');
        </text>
    }
    

    // burasi kullanici dropdownda secim yaptiginda tetiklenir. 
    document.getElementById('KategoriSec').addEventListener('change', function () {
// buradaki "const id" secilen <option value = 1> den 'value' degerini alir yani 1.
        const id = this.value;
// "const isim" ise secilen degerin ekranda gorulen metnini alir.
        const isim = this.options[this.selectedIndex].text;

        // id bossa veya daha onceden o id secildiyse
        if (id == "" || IdveIsimAlanMapKismi.has(id)) {
        //  bu kod dropdown menuyu sifirlamaya yariyor. yinede sor.
            this.value = '';
            return;
        }

    //  Kontrol alani gecildi. o halde id ve isim'i Map()'e kaydet.
        IdveIsimAlanMapKismi.set(id, isim);
    // "renderButonlar();" fonksiyonu "Map()" icinde bulunan verileri ekrana cizer.
        renderButonlar();
        this.value = ''; // Dropdown'ı sıfırla, tekrar seçilebilsin
    });

    function renderButonlar() {
    // bu kod "document.getElementById('olusanButon');" butonlarin konulacagi alani buluyor.
        const butonlarinKonulacagiAlan = document.getElementById('olusanButon');
    // bu kod "Map()" icindeki tum butonlari her seferinde ekrana yeniden yazmasin diye ekliyoruz.
    // bu alana her seferinde sadece secilen yazilsin diye ekledik.
        butonlarinKonulacagiAlan.innerHTML = '';

        IdveIsimAlanMapKismi.forEach(function(isim, id) {

            const _Buton = document.createElement('button');
            _Buton.type = 'button';
            _Buton.className = 'Kategori-Silme-Butonu mt-1 me-1';
            _Buton.textContent = isim;
            _Buton.addEventListener('click', function() {
                IdveIsimAlanMapKismi.delete(id); 
                renderButonlar();                
            });
            butonlarinKonulacagiAlan.appendChild(_Buton);

            const kategoriIdGonder = document.createElement("input")
            kategoriIdGonder.type = 'hidden';
            kategoriIdGonder.name = "KategoriIdParametre";
            kategoriIdGonder.value = id;

            butonlarinKonulacagiAlan.appendChild(kategoriIdGonder);


        });
    }

    // Sayfa yuklenince mevcut kategorileri ekrana ciz
    document.addEventListener('DOMContentLoaded', function () {
        renderButonlar();
    });
</script>




