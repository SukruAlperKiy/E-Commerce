@using System.Data
@{
    ViewData["Title"] = "Footer Logo Guncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    DataSet FooterLogoDataKumesi = ViewBag.FooterLogoKismiUpdate as DataSet;
}

<style>
    /* Örnek projedeki yükleme alanının şık görünmesi için küçük bir stil */
    .yukleme-alani {
        border: 2px dashed #dee2e6;
        padding: 25px;
        text-align: center;
        border-radius: 8px;
        background: #f8f9fa;
        cursor: pointer;
        transition: background 0.2s ease-in-out;
    }
    .yukleme-alani:hover {
        background: #e9ecef;
    }
</style>


<main class="main-content">
    <div class="container-fluid">
        @*<form ile baslayan alan, 'Kaydet' tusuna basildigi an tarayicidaki(google) verileri alip "Footer_Logo_Updates" isimli [HttpPost] methoduna gonderiyor.*@
        <form role="form" action="/Admin/Footer_Logo_Updates" method="post" enctype="multipart/form-data">
            <input type="hidden" name="FooterLogoId" value="@FooterLogoDataKumesi.Tables[0].Rows[0]["FooterLogoId"]"/>
            <input type="hidden" name="mevcutFotoUrl" value="@FooterLogoDataKumesi.Tables[0].Rows[0]["FooterLogoFotoUrl"]"/>
            

            @*Bu kisim FooterLogoAltBaslik'i text areadan mi aliyor ve nasil kaydediyor?*@
            <div class="col-md-12">
                <label class="form-label fw-bold"> Footer Logo Alt Baslik</label>
                @*buradaki 'name="FooterLogoAltBaslik"' kodundaki 'FooterLogoAltBaslik' controllerdeki methodun basinda aldigimiz "string FooterLogoAltBaslik" ile ayni olmak zorunda*@
                <textarea class="form-control shadow-none" name="FooterLogoAltBaslik" rows="1" placeholder="Alt Baslik">@FooterLogoDataKumesi.Tables[0].Rows[0]["FooterLogoAltBaslik"]</textarea>
            </div>



            <div class="col-md-6">
                <label class="form-label d-block mb-2">Yeni Fotograf Yukle</label>
                @*ekranda yukleme alani guzel gozuksun diye <style ile bir (yukleme-alani) tasarladik*@
                <div class="yukleme-alani" onclick="document.getElementById('fileInput').click()">
                    <p class="mb-1 fw-bold">Tiklayin Veya Resmi Buraya Surukleyip Birakin</p>
                    <p class="text-muted small mb-0">PNG, JPG, WEBP (Maks. 5MB)</p>
                    <input type="file" class="d-none" id="fileInput" name="resimFile" accept="image/*" onchange="yuklenenResmiGoruntule(event)"/>   
                </div>
            </div>



            <div class="col-md-6">
                <label class="form-label d-block mb-2 fw-bold"> Mevcut Fotograf</label>
                <div class="p-2 border rounded bg-light text-center" style="min-height: 145px; display: flex; align-items: center; justify-content: center;">
                    @*bu kod nasil calisiyor*@
                    <img id="onizleme" src="@FooterLogoDataKumesi.Tables[0].Rows[0]["FooterLogoFotoUrl"]" style="max-width:100%; max-height:130px; height:auto; border-radius:6px; object-fit: contain;" />
                </div>
            </div>

            <div class="mt-4 text-end border-top pt-3">
                <button type="submit" class="btn btn-primary px-4">Kaydet</button>
            </div>

        </form>
    </div>
</main>

<script>
    function yuklenenResmiGoruntule(event) {
        const secilenIlkDosya = event.target.files[0]; // Seçilen ilk dosyayı al
        const onizleme = document.getElementById('onizleme'); // Resim etiketini yakala

        if (!secilenIlkDosya) return;

        // 1. GÜVENLİK KONTROLÜ: Seçilen şey gerçekten resim mi?
        if (!secilenIlkDosya.type.startsWith('image/')) {
            alert("Lütfen geçerli bir resim dosyası seçiniz.");
            event.target.value = ""; // Seçimi temizle
            return;
        }

        // 2. BOYUT KONTROLÜ: Resim 5MB'tan büyük mü?
        const maxBuyukluk = 5 * 1024 * 1024; // 5 Megabayt bayt cinsinden
        if (secilenIlkDosya.size > maxBuyukluk) {
            alert("Seçtiğiniz resim 5MB'tan küçük olmalıdır.");
            event.target.value = ""; // Seçimi temizle
            return;
        }

        // 3. ANLIK ÖNİZLEME OLUŞTURMA
        const url = URL.createObjectURL(secilenIlkDosya); // Seçilen resmi tarayıcı hafızasında geçici bir linke dönüştür
        onizleme.src = url; // Ekrandaki mevcut resmin yerine bu yeni geçici linki bas
    }
</script>
