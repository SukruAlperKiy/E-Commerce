@using System.Data

@{
    ViewData["Title"] = "SliderSelect";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    DataSet SlidersSelectDataSet = ViewBag.SlidersSelectViewBag as DataSet;
}

<div class="container">
    <div class="page-inner"> 
        <div class="page-header">
            <h3 class="fw-bold mb-3">Sliders</h3>
            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Listeleri</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">One Cikan Kategoriler Operasyonlari</a>
                </li>
            </ul>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Hoverable Table</div>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th scope="col">Kapak Resim</th>
                                    <th scope="col">Isim</th>
                                    <th scope="col">Aciklama</th>
                                    <th scope="col">Urun Aktiflik</th>
                                    <th scope="col">Guncelle</th>
                                    <th scope="col">Sil</th>
                                </tr>
                            </thead>
                            @if (SlidersSelectDataSet != null && SlidersSelectDataSet.Tables.Count > 0 && SlidersSelectDataSet.Tables[0].Rows.Count > 0)
                            {
                                <tbody>
                                    @foreach (DataRow sira in SlidersSelectDataSet.Tables[0].Rows)
                                    {
                                        <tr>
                                            <td class="text-muted"><img src="@sira["ImageUrl"]" style="max-width:60px; max-height:60px; width:auto; height:auto; object-fit:contain; border-radius:4px;"/></td>
                                            <td class="text-muted">@sira["SliderTitle"]</td>
                                            <td class="text-muted">@sira["SliderKucukTitle"]</td>
                                            @* <td class="text-muted">@sira["UrunStatus"]</td> *@

                                            <td><a href="/SliderS/SliderUpdate/@sira["SliderId"]" class="btn btn-success">Guncelle</a></td>
                                            <td><a href="/SliderS/SliderDelete/@sira["SliderId"]" class="btn btn-danger">Sil</a></td>
                                        </tr>
                                    }
                                </tbody>
                            }
                            else
                            {
                                <tr>
                                    <td class="text-muted"> Gosterilecek Slider Bulunamadi </td>
                                </tr>
                            }
                        </table>
                        <a href="/SliderS/SliderInsert" class="btn btn-primary">Yeni Slider Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 
