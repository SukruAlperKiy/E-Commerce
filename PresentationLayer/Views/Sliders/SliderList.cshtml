@model List<EntityLayer.Concrete.Slider>

@{
    ViewData["Title"] = "SliderList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}



<div class="container">
    <div class="page-inner"> 
        <div class="page-header">
            <h3 class="fw-bold mb-3">Slider Listesi</h3>
            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Slider Listeleri</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Slider Operasyonlari</a>
                </li>
            </ul>
        </div>
            <div class="row">
              <div class="col-md-12">
                <div class="card">
                  <div class="card-header">
                    <div class="card-title">Bordered Table</div>
                  </div>
                  <div class="card-body">
                     <table class="table table-bordered table-head-bg-info table-bordered-bd-info table-hover mt-4">
                      <thead>
                        <tr>
                          <th scope="col">SliderID</th>
                          <th scope="col">SliderKucukTitle</th>
                          <th scope="col">SliderTitle</th>
                        </tr>
                      </thead>
                      <tbody>
                                @foreach (var esya in Model)
                                {
                                    <tr>
                                        <td>@esya.SliderId</td>
                                        <td>@esya.SliderKucukTitle</td>
                                        <td>@esya.SliderTitle</td>
                                         <td><a href="/Sliders/UpdateSlider/@esya.SliderId" class="btn btn-success">Guncelle</a></td>
                                         <td><a href="/Sliders/DeleteSlider/@esya.SliderId" class="btn btn-danger">Sil</a></td>
                                    </tr>
                                }
                      </tbody>
                    </table>
                    <a href="/Sliders/CreateSlider/" class="btn btn-primary">Yeni Slider Ekle</a>
                  </div>
                </div>
            </div>
        </div>
    </div>
</div> 