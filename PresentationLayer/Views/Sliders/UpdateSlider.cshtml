@model EntityLayer.Concrete.Slider;

@{
    ViewData["Title"] = "UpdateSlider";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container">
    <div class="page-inner"> 
        <div class="page-header">
            <h3 class="fw-bold mb-3">Slider Listesi</h3>
            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="/sliders/sliderlist/">Slider Listesi</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Slider Guncelle</a>
                </li>
            </ul>
        </div>
            <div class="row">
              <div class="col-md-12">
                <div class="card">
                  <div class="card-header">
                    <div class="card-title">Slideri Guncelle</div>
                  </div>
                  <div class="card-body">
                     <form method="post">
                         <input type="hidden" asp-for="SliderId" class="form-control" />
                         <label>Kucuk Slider Basligi</label>
                         <input type="text" asp-for="SliderKucukTitle" class="form-control" />
                         <br />
                         <label>Slider Basligi</label>
                         <input type="text" asp-for="SliderTitle" class="form-control" />
                         <br />
                         <label>Slider ImageUrl</label>
                         <textarea class="form-action" asp-for="ImageUrl"></textarea>
                         <br />
                         <button class="btn btn-primary">Slider Guncelle</button>

                     </form>
                  </div>
                </div>
            </div>
        </div>
    </div>
</div> 

