@model List<EntityLayer.Concrete.Slider>

    @foreach (var esya in Model)
    {
        <section class="welcome_area bg-img background-overlay" style="background-image: url(@esya.ImageUrl);">
            <div class="container h-100">
                <div class="row h-100 align-items-center">
                    <div class="col-12">
                        <div class="hero-content">
                    
                            <h6>@esya.SliderKucukTitle</h6>
                            <h4>@esya.SliderTitle</h4>
                            @* <a href="/sliders/sliderlist/" class="btn essence-btn">@esya.ImageUrl</a> *@
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }








