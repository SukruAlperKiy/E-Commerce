@model List<PresentationLayer.Models.Urunler1Model>

    <style>
        h2.cok-satan-urunler-baslik-rengi {
            color: #FF8C00;
        }

        p .siyah-renk-yazi{
            color: #000000;
        }

        .slider-alani{
            padding-left: 6.5% !important;
            padding-right: 6% !important;
        }

    </style>

<section class="new_arrivals_area section-padding-2 clearfix">
        <div class="container-fluid slider-alani">
            <div class="row">
                <div class="col-12">
                    <div class="section-heading text-left">
                        <h2 class="cok-satan-urunler-baslik-rengi">Çok Satan Ürünler</h2>
                        <p class="siyah-renk-yazi"><strong>Müşterilerimizin en çok tercih ettiği ürünleri görmek ister misiniz?</strong></p>
                    </div>
                </div>
            </div>
        </div>
    <!-- bu "container-fluid" kodu ekranin sagginda ve solunda hic bosluk kalmamasini sagliyor. (eskiden container vardi.)-->
        <div class="container-fluid slider-alani">
            <div class="row">
                <div class="col-12">
                    <div class="popular-products-slides owl-carousel">

                    @foreach (var deger in Model)
                    {
                        <div class="single-product-wrapper">
                            <div class="product-img">
                                <img src="@deger.urunlerKapakFoto" alt="">
                                <img class="hover-img" src="/BUDUR-e-commerce/img/product-img/product-4.jpg" alt="">
                                @* <div class="product-favourite">
                                    <a href="#" class="favme fa fa-heart"></a>
                                </div> *@
                            </div>
                            <div class="product-description">
                                <span>MSI</span>
                                <a href="single-product-details.html">
                                    <h6>@deger.urunlerIsim</h6>
                                </a>
                                <p class="product-price">₺@deger.urunlerFiyat</p>
                                @* <div class="hover-content">
                                    <div class="add-to-cart-btn">
                                        <a href="#" class="btn essence-btn">Sepete Ekle</a>
                                    </div>
                                </div> *@
                            </div>
                        </div>
                    }
                    </div>
                </div>
            </div>
        </div>
    </section>