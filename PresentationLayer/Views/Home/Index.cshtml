@{
    Layout = null;
    ViewData["Title"] = "Home Page";
}



<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="description" content="">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- The above 4 meta tags *must* come first in the head; any other head content must come *after* these tags -->

    <!-- Title  -->
    <title>Essence - Fashion Ecommerce Template</title>

    <!-- Favicon  -->
    <link rel="icon" href="/BUDUR-e-commerce/img/core-img/favicon.ico">
    

    <!-- Core Style CSS -->
    <link rel="stylesheet" href="/BUDUR-e-commerce/css/core-style.css">
    <link rel="stylesheet" href="style.css">

    <!-- Font Awesome-->
    <link rel="stylesheet" href="/BUDUR-e-commerce/css/font-awesome.min.css">

</head>

<body>
    <!-- ##### Header Area Start ##### -->
    @await Component.InvokeAsync("_HomeHeaderAreaSectionComponentPartial")
    <!-- ##### Header Area End ##### -->

    <!-- ##### Right Side Cart Area ##### -->
    @await Component.InvokeAsync("_HomeRightSideChartSectionComponentPartial")
    <!-- ##### Right Side Cart End ##### -->

        <!-- ##### Welcome Area Start ##### -->
        @await Component.InvokeAsync("_HomeWelcomeAreaSectionComponentPartial")
        <!-- ##### Welcome Area End ##### -->
    
        <!-- ##### New Arrivals Area Start ##### -->
        @await Component.InvokeAsync("_HomeNewArrivalsAreaSectionComponentPartial")
        <!-- ##### New Arrivals Area End ##### -->

        <!-- ##### Top Catagory Area Start ##### -->
        @await Component.InvokeAsync("_HomeTopCategoryAreaSectionComponentPartial")
        <!-- ##### Top Catagory Area End ##### -->

        <!-- ##### CTA Area Start ##### -->
        @await Component.InvokeAsync("_HomeCTAAreaSectionComponentPartial")
        <!-- ##### CTA Area End ##### -->

        <!-- ##### Brands Area Start ##### -->
        @await Component.InvokeAsync("_HomeBrandsAreaSectionComponentPartial")
        <!-- ##### Brands Area End ##### -->

    <!-- ##### Footer Area Start ##### -->
    @await Component.InvokeAsync("_HomeFooterSectionComponentPartial")
    <!-- ##### Footer Area End ##### -->



    <!-- jQuery (Necessary for All JavaScript Plugins) -->
    <script src="/BUDUR-e-commerce/js/jquery/jquery-2.2.4.min.js"></script>
    <!-- Popper js -->
    <script src="/BUDUR-e-commerce/js/popper.min.js"></script>
    <!-- Bootstrap js -->
    <script src="/BUDUR-e-commerce/js/bootstrap.min.js"></script>
    <!-- Plugins js -->
    <script src="/BUDUR-e-commerce/js/plugins.js"></script>
    <!-- Classy Nav js -->
    <script src="/BUDUR-e-commerce/js/classy-nav.min.js"></script>
    <!-- Active js -->
    <script src="/BUDUR-e-commerce/js/active.js"></script>

</body>

</html>


